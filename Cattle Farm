<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Inter', sans-serif; background: #050505; color: #fff; overflow-x: hidden; }
  
  body::before {
    content: ''; position: fixed; inset: 0; z-index: 9999; pointer-events: none; opacity: 0.03;
