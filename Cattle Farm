  .btn-emerald {
    background: #10b981; color: #000; font-weight: 600; padding: 12px 28px; border-radius: 999px;
    border: none; cursor: pointer; font-size: 14px; transition: all 0.3s;
    box-shadow: 0 0 20px rgba(16,185,129,0.3);
  }
  .btn-emerald:hover { box-shadow: 0 0 40px rgba(16,185,129,0.5); transform: translateY(-2px); }

  .input-dark {
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
    color: #fff; padding: 12px 16px; border-radius: 12px; font-size: 14px;
    font-family: 'Inter', sans-serif; outline: none; transition: all 0.3s; width: 100%;
  }
  .input-dark:focus { border-color: #10b981; box-shadow: 0 0 0 3px rgba(16,185,129,0.15); }
  .input-dark::placeholder { color: #525252; }
  select.input-dark { appearance: none; cursor: pointer; }

  .nav-link { color: #a3a3a3; transition: color 0.3s; text-decoration: none; font-size: 13px; font-weight: 500; letter-spacing: 0.02em; }
  .nav-link:hover { color: #fff; }

  .spotlight-1 { position: absolute; width: 600px; height: 600px; background: radial-gradient(circle, rgba(16,185,129,0.12), transparent 70%); border-radius: 50%; filter: blur(60px); pointer-events: none; }
  .spotlight-2 { position: absolute; width: 500px; height: 500px; background: radial-gradient(circle, rgba(168,85,247,0.08), transparent 70%); border-radius: 50%; filter: blur(80px); pointer-events: none; }

  .grid-bg {
    background-size: 40px 40px;
    background-image: linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px),
                      linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px);
  }

  .marquee-track { display: flex; gap: 48px; width: max-content; }

  .toast {
    position: fixed; bottom: 100px; right: 20px; z-index: 10000;
    padding: 16px 24px; border-radius: 16px;
    background: rgba(16,185,129,0.15); backdrop-filter: blur(16px);
    border: 1px solid rgba(16,185,129,0.3); color: #10b981;
    font-size: 14px; font-weight: 500;
    transform: translateX(120%); transition: transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94);
  }
  .toast.show { transform: translateX(0); }

  .mobile-menu { max-height: 0; overflow: hidden; transition: max-height 0.4s ease; }
  .mobile-menu.open { max-height: 300px; }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #050505; }
  ::-webkit-scrollbar-thumb { background: #262626; border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: #404040; }

  .hero-img-overlay {
    mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
